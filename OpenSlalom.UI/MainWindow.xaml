<Window x:Class="OpenSlalom.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:OpenSlalom.UI"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="openSlalom"
        Icon="/icons/logo.png"
        Height="768"
        Width="1280"
        MinHeight="640"
        MinWidth="1024"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#F8FAFC"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <local:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <local:SvgResourceToImageSourceConverter x:Key="SvgResourceToImageSourceConverter" />
        <local:ZeitstrafeConverter x:Key="ZeitstrafeConverter" />
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0"/>



            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
             VerticalAlignment="Center"/>

                                <Border x:Name="HoverOverlay"
                               Background="Black"
                               Opacity="0"
                               IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay"
                                 Property="Opacity"
                     Value="0.15"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Button" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0"/>



            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">

                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                                <Border x:Name="HoverOverlay"
                                Background="Black"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay"
                                 Property="Opacity"
                     Value="0.15"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonRight" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0"/>



            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="0,4,4,0"
                            Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                                <Border x:Name="HoverOverlay"
                                 Background="Black"
                                 Opacity="0"
                                 IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay"
                                 Property="Opacity"
                     Value="0.15"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonLeft" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0"/>



            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                      CornerRadius="4,0,0,4"
                      Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
             VerticalAlignment="Center"/>

                                <Border x:Name="HoverOverlay"
                               Background="Black"
                               Opacity="0"
                               IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay"
                                 Property="Opacity"
                     Value="0.15"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButtonSync" TargetType="Button">
            <Setter Property="Background" Value="#1F84DE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,0,5,0"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="18"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="TabBorder"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                            </Border>


                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#D1D5DB" />

                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StandardDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Path x:Name="SortArrow"
                                      Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="Black"
                                      Data="M 0 6 L 4 0 L 8 6 Z"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 6 L 4 0 L 8 6 Z" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 4 6 L 8 0 Z" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StandardDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="StandardDataGridTextElementStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="StandardDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#E0E0E0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowRootBorder" Margin="0" CornerRadius="0" BorderThickness="0" BorderBrush="Transparent" Background="#F8FAFC">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>


            <!-- Header -->
            <Border Grid.Row="0" Background="White" CornerRadius="0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Image Source="/icons/logo.png" Width="30" HorizontalAlignment="Left" Margin="15,0,0,0"/>
                    <TextBlock Margin="56,0,0,0" VerticalAlignment="Center" FontSize="20" Foreground="#1F84DE" FontWeight="Bold" Text="openSlalom" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,5,0">
                        <Image Source="/icons/minimize.png" Width="30" HorizontalAlignment="Left" Margin="15,0,0,0" MouseLeftButtonDown="MinimizeButton_OnClick"/>
                        <Image x:Name="MaximizeRestoreImage" Source="/icons/maximize.png" Width="30" HorizontalAlignment="Left" Margin="15,0,0,0" MouseLeftButtonDown="MaximizeButton_OnClick"/>
                        <Image Source="/icons/close.png" Width="30" HorizontalAlignment="Left" Margin="15,0,0,0" MouseLeftButtonDown="CloseButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border x:Name="SidebarBorder" Background="Transparent" BorderBrush="LightGray" BorderThickness="0,0,1,0">
                        <StackPanel x:Name="MenuPanel">
                        <Button x:Name="MenuStartseite" Style="{StaticResource MenuButtonStyle}" Padding="12,10" HorizontalContentAlignment="Left" Content="Startseite" Tag="Startseite" Click="MenuButton_OnClick" />
                        <Button x:Name="MenuTrainings" Style="{StaticResource MenuButtonStyle}" Padding="10,10" HorizontalContentAlignment="Left" Content="Trainings" Tag="Trainings" Click="MenuButton_OnClick" />
                        <Button Style="{StaticResource MenuButtonStyle}" Padding="10,10" HorizontalContentAlignment="Left" Content="Meisterschaften" Tag="Meisterschaften" Click="MenuButton_OnClick" />
                        <Button Style="{StaticResource MenuButtonStyle}" Padding="12,10" HorizontalContentAlignment="Left" Content="Statistiken" Tag="Statistiken" Click="MenuButton_OnClick" />
                        <Button Style="{StaticResource MenuButtonStyle}" Padding="12,10" HorizontalContentAlignment="Left" Content="Einstellungen" Tag="Einstellungen" Click="MenuButton_OnClick" />
                        <Button x:Name="MenuSettingsVereine" Style="{StaticResource MenuButtonStyle}" Padding="28,8,10,8" HorizontalContentAlignment="Left" Content="- Vereine" Tag="Vereine" Click="MenuButton_OnClick" Visibility="Collapsed" />
                        <Button x:Name="MenuSettingsFahrer" Style="{StaticResource MenuButtonStyle}" Padding="28,8,10,8" HorizontalContentAlignment="Left" Content="- Fahrer" Tag="Fahrer" Click="MenuButton_OnClick" Visibility="Collapsed" />
                        <Button x:Name="MenuSettingsDisziplin" Style="{StaticResource MenuButtonStyle}" Padding="28,8,10,8" HorizontalContentAlignment="Left" Content="- Disziplin" Tag="Disziplin" Click="MenuButton_OnClick" Visibility="Collapsed" />
                        <Button x:Name="MenuSettingsKarts" Style="{StaticResource MenuButtonStyle}" Padding="28,8,10,8" HorizontalContentAlignment="Left" Content="- Karts" Tag="Karts" Click="MenuButton_OnClick" Visibility="Collapsed" />
                        <Button x:Name="MenuSettingsWetter" Style="{StaticResource MenuButtonStyle}" Padding="28,8,10,8" HorizontalContentAlignment="Left" Content="- Wetter" Tag="Wetter" Click="MenuButton_OnClick" Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                    <Button x:Name="SidebarToggleButton"
                            Width="22"
                            Height="86"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,-11,0"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Click="ToggleSidebar_OnClick"
                            Panel.ZIndex="2">
                        <TextBlock x:Name="SidebarToggleIcon"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Text="◀" />
                    </Button>
                </Grid>

                <Grid Grid.Column="1" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="2">
                       
                        <Border x:Name="StartseitePage" Visibility="Visible" Background="Transparent">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="LogoImage" Height="320" Stretch="Uniform" Source="/icons/logo.png" ImageFailed="LogoImage_OnImageFailed" />
                                <TextBlock Margin="0,20,0,0" FontSize="48" FontWeight="Bold" Foreground="#1F84DE" Text="openSlalom" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="TrainingsPage" Visibility="Collapsed" Background="Transparent">
                            <Grid Margin="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontWeight="Bold" FontSize="20" Text="Trainings" VerticalAlignment="Center" />

                                    <Button Grid.Column="1" Background="#1F84DE" Style="{StaticResource RoundedButton}" Content="Training anlegen" Width="120"  Height="30" Click="OpenCreateTrainingPage_OnClick" />
                                </Grid>

                                <Grid Grid.Row="2">
                                    <DataGrid x:Name="TrainingsDataGrid"
                                                  ItemsSource="{Binding TrainingItems}"
                                                  Background="Transparent"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="None"
                                                  BorderThickness="0"
                                                  RowHeaderWidth="0"
                                                  MinRowHeight="36"
                                                  VerticalContentAlignment="Center"
                                                  SelectionMode="Single"
                                                  AlternationCount="2"
                                                  ColumnHeaderStyle="{StaticResource StandardDataGridHeaderStyle}"
                                                  CellStyle="{StaticResource StandardDataGridCellStyle}"
                                                  RowStyle="{StaticResource StandardDataGridRowStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Datum" Binding="{Binding ZeitpunktText}" Width="80" ElementStyle="{StaticResource StandardDataGridTextElementStyle}"/>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="16*" ElementStyle="{StaticResource StandardDataGridTextElementStyle}"/>
                                            <DataGridTextColumn Header="Beschreibung" Binding="{Binding Beschreibung}" Width="20*" ElementStyle="{StaticResource StandardDataGridTextElementStyle}" />
                                            <DataGridTextColumn Header="Verein" Binding="{Binding VereinName}" Width="16*" ElementStyle="{StaticResource StandardDataGridTextElementStyle}" />
                                            <DataGridTextColumn Header="Disziplin" Binding="{Binding DisziplinName}" Width="80" ElementStyle="{StaticResource StandardDataGridTextElementStyle}" />
                                            <DataGridTextColumn Header="Wetter" Binding="{Binding WetterName}" Width="120" ElementStyle="{StaticResource StandardDataGridTextElementStyle}"/>
                                            <DataGridTextColumn Header="Finished" Binding="{Binding TrainingAbgeschlossenText}" Width="80" ElementStyle="{StaticResource StandardDataGridTextElementStyle}" />
                                            <DataGridTemplateColumn Header="Aktionen" Width="125">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Height="32" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="10"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Button Grid.Column="1" Height="28"  Style="{StaticResource RoundedButtonLeft}" Background="#1F84DE" Tag="{Binding Id}" Click="OpenDetailTrainingPage_OnClick">
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" />
                                                            </Button>
                                                            <Button Grid.Column="2" Height="28"  Style="{StaticResource Button}" Background="#1F84DE" Tag="{Binding Id}" Click="OpenEditTrainingPage_OnClick">
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" />
                                                            </Button>
                                                            <Button Grid.Column="3"  Height="28" Style="{StaticResource RoundedButtonRight}" Background="Red"  Tag="{Binding Id}" Click="OpenDeleteTrainingPage_OnClick">
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" />
                                                            </Button>

                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border x:Name="TrainingCreatePage" Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                        <StackPanel Margin="20">
                                            <TextBlock FontWeight="Bold" FontSize="18" Text="Training anlegen" />
                                            <TextBlock Margin="0,16,0,4" Text="Name" />
                                            <TextBox x:Name="CreateTrainingNameTextBox" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Beschreibung" />
                                            <TextBox x:Name="CreateTrainingBeschreibungTextBox" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Datum" />
                                            <DatePicker x:Name="CreateTrainingZeitpunktPicker" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Verein" />
                                            <ComboBox x:Name="CreateTrainingVereinComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <TextBlock Margin="0,12,0,4" Text="Disziplin" />
                                            <ComboBox x:Name="CreateTrainingDisziplinComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <TextBlock Margin="0,12,0,4" Text="Wetter" />
                                            <ComboBox x:Name="CreateTrainingWetterComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <CheckBox x:Name="CreateTrainingAbgeschlossenCheckBox" Margin="0,12,0,0" Content="Training abgeschlossen" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                                <Button Style="{StaticResource RoundedButton}" Background="#1F84DE" Width="120"  Height="30"  Margin="0,0,8,0" Click="CancelTrainingPage_OnClick" Content="Abbrechen" />
                                                <Button Style="{StaticResource RoundedButton}" Background="green" Width="120" Height="30"  Click="SaveCreateTraining_OnClick" Content="Speichern" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="TrainingEditPage" Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                        <StackPanel Margin="20">
                                            <TextBlock FontWeight="Bold" FontSize="18" Text="Training bearbeiten" />
                                            <TextBlock Margin="0,16,0,4" Text="Name" />
                                            <TextBox x:Name="EditTrainingNameTextBox" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Beschreibung" />
                                            <TextBox x:Name="EditTrainingBeschreibungTextBox" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Datum" />
                                            <DatePicker x:Name="EditTrainingZeitpunktPicker" Height="30" />
                                            <TextBlock Margin="0,12,0,4" Text="Verein" />
                                            <ComboBox x:Name="EditTrainingVereinComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <TextBlock Margin="0,12,0,4" Text="Disziplin" />
                                            <ComboBox x:Name="EditTrainingDisziplinComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <TextBlock Margin="0,12,0,4" Text="Wetter" />
                                            <ComboBox x:Name="EditTrainingWetterComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" />
                                            <CheckBox x:Name="EditTrainingAbgeschlossenCheckBox" Margin="0,12,0,0" Content="Training abgeschlossen" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                                <Button Style="{StaticResource RoundedButton}" Background="#1F84DE" Width="120" Height="30"  Margin="0,0,8,0" Click="CancelTrainingPage_OnClick" Content="Abbrechen" />
                                                <Button Style="{StaticResource RoundedButton}" Background="green" Width="120" Height="30"  Click="SaveEditTraining_OnClick" Content="Speichern" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="TrainingDeletePage" Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                        <StackPanel Margin="20">
                                            <TextBlock FontWeight="Bold" FontSize="18" Text="Training loeschen" />
                                            <TextBlock Margin="0,16,0,0" Text="Soll dieses Training wirklich geloescht werden?" />
                                            <TextBlock x:Name="DeleteTrainingTextBlock" Margin="0,10,0,0" FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                                <Button  Width="120" Height="30" Margin="0,0,8,0" Click="CancelTrainingPage_OnClick" Content="Abbrechen" />
                                                <Button  Width="120"  Height="30" Background="#DC2626" Foreground="White" BorderThickness="0" Click="ConfirmDeleteTraining_OnClick" Content="Loeschen" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="TrainingStatisticsPage" Visibility="Collapsed" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="TrainingStatisticsScrollViewer" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="20">
                                    <TextBlock x:Name="TrainingStatisticsTitleTextBlock" FontSize="24" FontWeight="Bold" Text="Training" />

                                        <Grid Margin="0,10,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30" />
                                                <RowDefinition Height="40" />
                                            </Grid.RowDefinitions>
                                            <TextBlock x:Name="TrainingStatisticsParticipantsTextBlock" Grid.Row="0" Text="Teilnehmer: -" FontSize="14" />
                                        <TextBlock x:Name="TrainingStatisticsTimeRangeTextBlock" Grid.Row="1" Text="Uhrzeit: -" FontSize="18" Foreground="DarkGray"/>
                                        </Grid>


                                    <DataGrid x:Name="TrainingStatisticsBestLapsDataGrid"
                                              Margin="0,14,0,0"
