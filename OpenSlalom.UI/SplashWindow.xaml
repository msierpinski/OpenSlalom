<Window x:Class="OpenSlalom.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSlalom"
        Icon="/icons/logo.png"
        Width="420"
        Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">
    <Border CornerRadius="14" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Image Height="140" Stretch="Uniform" Source="/icons/logo.png" />
                <TextBlock Margin="0,14,0,0"
                           Text="openSlalom"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#1F84DE"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="Wird gestartet..."
                       Foreground="#475569"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />
        </Grid>
    </Border>
</Window>
